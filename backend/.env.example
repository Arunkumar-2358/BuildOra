NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/buildora
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_URL=http://localhost:5173
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin bootstrap — if both are set, an admin account is ensured on startup
ADMIN_EMAIL=admin@buildora.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Buildora Admin

# Payments — provider is "mock" (local dev only; no keys, instant fake activation)
#   | "razorpay" | "stripe".
# In DEVELOPMENT, selecting a gateway without its keys falls back to mock so demos
# work. In PRODUCTION (NODE_ENV=production) the mock provider and any unconfigured
# gateway are REFUSED — checkout returns 503 instead of activating a free
# subscription. So for real payments: set PAYMENT_PROVIDER=razorpay AND fill in the
# keys below (get them from Razorpay Dashboard → Settings → API Keys).
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay Dashboard → Settings → Webhooks. Subscribe to payment.captured,
# order.paid, payment.failed and point it at POST /api/webhooks/razorpay.
RAZORPAY_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Shared secret for serverless cron triggers: POST /api/cron/:job with header x-cron-secret.
CRON_SECRET=
# Set to "true" to disable in-process node-cron (e.g. on serverless with external cron).
DISABLE_CRON=

# Email / SMTP — used for forgot-password reset links.
# Leave blank in local dev: the reset URL prints to the server console instead.
# Gmail: host=smtp.gmail.com, port=587, secure=false, user=you@gmail.com, pass=<app-password>
# SendGrid SMTP relay: host=smtp.sendgrid.net, port=587, user=apikey, pass=<sg.key>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@buildora.com
