VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Optional — enables the interactive Google Map + city/pincode geocoding.
# Without it, distances and matching still work (map shows a placeholder).
# Enable "Maps JavaScript API" + "Geocoding API" in Google Cloud, then restrict
# the key by HTTP referrer (localhost + your deployed domain).
VITE_GOOGLE_MAPS_API_KEY=
